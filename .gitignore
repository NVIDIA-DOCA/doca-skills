# macOS Finder noise — must never enter the public bundle.
# The check-reference-hygiene.sh CI gate also fails on any .DS_Store
# anywhere under the bundle root.
.DS_Store
**/.DS_Store

# Python bytecode caches — produced by the runner/ scripts on first use.
__pycache__/
**/__pycache__/
*.pyc

# Per-run measurement artifacts produced by runner/ab_runner.py and the
# ad-hoc A/B/C subagent driver. Each run produces a dated directory
# (runner/reports/<YYYY-MM-DD_runid>/) containing subagent prompts,
# variant responses, grader JSON, and HTML; these are reproducible
# from the prompt corpus + skills bundle and should not be committed.
runner/reports/

// doca-skills/ci/Jenkinsfile.skills.ci
//
// CI pipeline for the doca-skills bundle, vendored into the bundle itself.
// All bundle tooling (ci/, runner/, fixtures/, env/, AUTHORING.md,
// CONTRIBUTING.md, SECURITY.md) now lives under doca-skills/ — the
// previous devops/ sister directory has been folded in. This file uses
// the shared @Library('doca-jenkins-library') so the GitHub clone
// credential is bound automatically by GitUtils.checkoutProject() rather
// than hard-coded with credentialsId: '...'.
//
// What this pipeline guarantees on every PR (the "huge test coverage"
// contract requested in the May-2026 reviewer-feedback wave):
//
//   1. Strict-to-doca version alignment (HARD).
//      Clone @doca at DOCA_BRANCH and run ci/check-doca-inventory.sh.
//      Bundle skill dirs must be 1:1 with doca/{libs,services,tools}.
//
//   2. Per-skill structural conformance (HARD).
//      ci/check-skill.sh --all --check-urls — every SKILL.md /
//      CAPABILITIES.md / TASKS.md has the required anchors,
//      public-sources allowlist, AUTHORING § 1a class-shape filenames.
//
//   3. Frontmatter validation (HARD).
//      claude-skill-check against every SKILL.md — 0 errors required.
//
//   4. Cross-link integrity (HARD).
//      ci/check-crosslinks.sh — every relative-path link AND every
//      #anchor target must resolve. 7370+ links audited per run.
//
//   5. Anchor density (HARD).
//      ci/check-anchor-density.sh --all — no stub anchors anywhere.
//
//   6. Structural keystone gate (HARD).
//      ci/check-keystones.sh — 42 load-bearing keystones (universal
//      verification contract, debug-loop contract, binding-layer stanza,
//      Stage 1 vs Stage 2 staged-roadmap rule, NGC tag selection rule,
//      resume-point hand-off, per-library rollback overlays, etc.)
//      must all be present. Self-test runs nightly with --self-test to
//      cross-check the gate itself (36/36 perturbations caught).
//
//   7. Reference hygiene (HARD).
//      ci/check-reference-hygiene.py — no internal-only path leaks
//      (`../devops/`, `future-plan/`), no broken local links, no
//      misleading anchor labels, no audit-history in runtime SKILL.md
//      files, no .DS_Store. Reviewer-feedback regression guard.
//
//   8. Coverage gates (HARD @ 100%).
//      ci/check-coverage.sh — every libs/services/tools skill MUST have
//      ≥1 prompt naming it via baseline_artifact:, and every public DOCA
//      lib/service/tool MUST have a 3-file skill dir.
//
//   9. Live-hardware harness self-test (HARD in fixture mode).
//      ci/check-live-hardware-harness.sh — Lane D runner-harness check
//      (auto/fixtures/live/dry-run modes, mutating-token rejection list,
//      v1 fixture-pack import integrity). Real-hardware execution is
//      gated separately on a connected host (when the operator sets
//      ENABLE_LIVE_HW=true and a BlueField is visible to the agent).
//
//  10. JTBD coverage (SOFT WARN by default).
//      ci/check-jtbd-coverage.sh — compares bundle-claimed JTBD coverage
//      against fresh extractions; emits FULL / PARTIAL / GAP.
//
//  11. 3-way A/B/C agent test (the headline measurement).
//      runner/ab_runner.py — variant A (no skills) vs variant B
//      (PREVIOUS_REV, default origin/main) vs variant C (PR HEAD). Runs
//      against EVERY prompt under runner/prompts/ (FULL_BUNDLE_SMOKE
//      defaults to true here, the opposite of the legacy diff-driven
//      mode, because the reviewer-feedback wave promised every-prompt
//      coverage on every PR for any reviewer to re-measure end-to-end).
//      Operators can flip FULL_BUNDLE_SMOKE=false to fall back to
//      select_prompts.py's diff-driven subset for quick iteration.
//
//  12. NGC container compile + link half (when DOCA_NGC_TAG set).
//      env/ngc_container.sh pulls the public NGC DOCA container; the
//      runner extracts every first-app command the C variant recommended
//      and executes it inside the container, asserting the build half
//      actually compiles and links against /opt/mellanox/doca/.
//
//  13. Publish HTML + JSON report + PR comment.
//      runner/ab_runner.py emits report.html + report.json with full
//      per-prompt per-criterion verdicts; the publishHTML step makes
//      the HTML browsable from Jenkins, and a curl call posts the
//      A/B/C headline + report URL back to the GitHub PR as a comment.
//
// Required Jenkins credentials (provided by doca-jenkins-library
// Constants when GitUtils.checkoutProject is used, so no hard-coding
// in this file):
//   - GITHUB_HTTPS_CRED_ID         (=svc-doca-devops-github-com-api-token)
//     Used by GitUtils.checkoutProject('github', ...) for HTTPS git clone
//     of github.com/NVIDIA-DOCA/doca-skills.git and github.com/NVIDIA/doca.git.
//   - GITHUB_HTTPS_USER_PASS_ID    (=svc-doca-devops-github-com-user-password)
//     Used by GitUtils.commit / .push if this pipeline ever pushes
//     follow-up commits (it currently does not).
//   - doca-skills-agent-api-key    (this pipeline's own credential)
//     API key for the AgentAdapter / JudgeAdapter (see ab_runner.py
//     docstring). Optional in dry-run mode.
//   - doca-skills-ngc-creds        (optional)
//     NGC API key for non-anonymous DOCA container pulls.
//
// Triggers:
//   - SCM webhook on every PR / push to doca-skills.
//   - Nightly cron for URL-drift detection + full-prompt regression run.

@Library('doca-jenkins-library') _

import org.nvidia.doca.GitUtils
import org.nvidia.doca.Constants

// --- Configuration knobs ---------------------------------------------------
// Exposed as parameters so a maintainer can re-run with different refs
// without editing this file.
def DEFAULTS = [
    SKILLS_REPO_URL              : "${Constants.GITHUB_HTTPS_BASE_URL}/NVIDIA-DOCA/doca-skills.git",
    SKILLS_REPO_DEFAULT_BRANCH   : 'main',
    DOCA_REPO_URL                : "${Constants.GITHUB_HTTPS_BASE_URL}/NVIDIA/doca.git",
    DOCA_REPO_DEFAULT_BRANCH     : 'master',
    PYTHON_VERSION               : '3.11',
    SKILLS_REF_VERSION           : 'skills-ref',
    AGENT_ADAPTER                : 'env.AGENT_ADAPTER must be set by the operator (module.path:Class)',
    JUDGE_ADAPTER                : 'env.JUDGE_ADAPTER must be set by the operator (module.path:Class)',
    NGC_TAG                      : 'env.DOCA_NGC_TAG must be set by the operator (e.g. 3.3.0-devel)',
]

pipeline {
    agent {
        kubernetes {
            yaml libraryResource("pods/jnlp.yaml")
        }
    }

    parameters {
        string(name: 'SKILLS_BRANCH',
               defaultValue: 'main',
               description: 'doca-skills branch (or PR ref) to test as `pr` (variant C).')
        string(name: 'PREVIOUS_REV',
               defaultValue: 'origin/main',
               description: 'Git rev to use as the `main` baseline (variant B) in the 3-agent A/B/C. ' +
                            'Defaults to `origin/main` — the reviewer-feedback wave proved that `main` ' +
                            'is the correct previous-wave reference, but it must point at the actual ' +
                            'bundle state, not at a reverted README-only commit. Override only for ' +
                            'inter-commit drift investigations.')
        string(name: 'DOCA_BRANCH',
               defaultValue: 'master',
               description: 'DOCA monorepo branch / tag / SHA to align the skills bundle against. ' +
                            'Strict-to-doca CI clones github.com/NVIDIA/doca.git, checks out this ref, ' +
                            'reads doca/VERSION, and runs ci/check-doca-inventory.sh as a HARD gate. ' +
                            'For a DOCA 3.5 alignment run, override to `doca_3.5`.')
        string(name: 'DOCA_NGC_TAG',
               defaultValue: '',
               description: 'NGC DOCA container tag for the full_compile sub-protocol. ' +
                            'Required if the A/B/C runner is allowed to extract + execute commands. ' +
                            'See doca-skills/skills/doca-public-knowledge-map/MAINTAINERS-NOTES.md ' +
                            '## URL audit log for the tag the bundle currently certifies.')
        booleanParam(name: 'FULL_BUNDLE_SMOKE',
                     defaultValue: true,
                     description: 'Run EVERY prompt under runner/prompts/ in the A/B/C measurement. ' +
                                  'Defaults to true per the May-2026 reviewer-feedback wave — every PR ' +
                                  'must produce a full per-artifact verdict for any reviewer to ' +
                                  're-measure end-to-end. Flip to false to use the diff-driven subset ' +
                                  'from select_prompts.py for quick iteration runs only.')
        booleanParam(name: 'APP_EXAMPLE_DRY_RUN',
                     defaultValue: false,
                     description: 'Skip docker exec; treat all extracted commands as exit-0. ' +
                                  'Use for runner-only debugging when no agent / NGC creds are set up.')
        booleanParam(name: 'ENABLE_LIVE_HW',
                     defaultValue: false,
                     description: 'Run the live-hardware path of runner/run_with_live_hardware.py ' +
                                  'in addition to the fixture-mode self-test. Set true only on an ' +
                                  'agent that has a real BlueField visible via lspci (production lab). ' +
                                  'The fixture-mode self-test always runs; this knob adds the real-HW ' +
                                  'capture pass on top.')
    }

    triggers {
        // SCM trigger is configured in the multibranch / GitHub job;
        // here we only schedule the nightly drift + full-corpus run.
        cron('H 4 * * *')
    }

    options {
        ansiColor('xterm')
        timestamps()
        skipDefaultCheckout true
        buildDiscarder(logRotator(numToKeepStr: '40'))
        timeout(time: 120, unit: 'MINUTES')
    }

    environment {
        SKILLS_REPO_URL  = "${DEFAULTS.SKILLS_REPO_URL}"
        DOCA_REPO_URL    = "${DEFAULTS.DOCA_REPO_URL}"
        SKILLS_DIR       = "${env.WORKSPACE}/doca-skills"
        DOCA_DIR         = "${env.WORKSPACE}/doca"
        WORKDIR          = "${env.WORKSPACE}/_run"
        REPORT_DIR       = "${env.WORKSPACE}/_run/report"
        AGENT_API_KEY    = credentials('doca-skills-agent-api-key')
    }

    stages {

        stage('Checkout doca-skills (PR ref) — library helper, no hard-coded creds') {
            steps {
                script {
                    sh "rm -rf ${env.SKILLS_DIR} ${env.WORKDIR}"
                    // GitUtils.checkoutProject('github', ...) reads
                    // Constants.GITHUB_HTTPS_CRED_ID for the credentialsId,
                    // so we never spell the credential id in this file —
                    // changing the org's GitHub credential rotates here
                    // automatically via the library Constants class.
                    def gitUtils = new GitUtils(this)
                    gitUtils.checkoutProject(
                        'github',                                       // scmName -> picks Constants.GITHUB_HTTPS_CRED_ID
                        params.SKILLS_BRANCH,                           // sourceBranch (PR ref or branch)
                        false,                                          // withSubmodules
                        "${env.SKILLS_REPO_URL.replace(Constants.GITHUB_HTTPS_BASE_URL + '/', '')}",  // projectUrl (path under github.com/)
                        'doca-skills',                                  // relativeTargetDir
                        false,                                          // shallowClone — false because the keystone + lint gates need history for git worktree --previous-rev
                        null,                                           // tag
                        null,                                           // customRefspec
                        false                                           // noMerge
                    )
                    dir(env.SKILLS_DIR) {
                        // The default-branch fetch is required for the
                        // `Lint — main baseline` and `Select prompts`
                        // stages; both diff against ${params.PREVIOUS_REV}.
                        sh "git fetch origin ${DEFAULTS.SKILLS_REPO_DEFAULT_BRANCH} --depth=50"
                    }
                    sh "ls -la ${env.SKILLS_DIR}"
                }
            }
        }

        stage('Checkout doca/ at DOCA_BRANCH (version anchor) — library helper') {
            steps {
                script {
                    sh "rm -rf ${env.DOCA_DIR}"
                    // Same pattern: use the library helper so the
                    // credentialsId comes from Constants, not this file.
                    def gitUtils = new GitUtils(this)
                    gitUtils.checkoutProject(
                        'github',
                        params.DOCA_BRANCH,
                        false,
                        "${env.DOCA_REPO_URL.replace(Constants.GITHUB_HTTPS_BASE_URL + '/', '')}",
                        'doca',
                        true,                                           // shallowClone — only need libs/services/tools dirs + VERSION
                        null,
                        null,
                        false
                    )
                    def docaVer = sh(returnStdout: true, script:
                        "cat ${env.DOCA_DIR}/VERSION 2>/dev/null || echo '<no-VERSION>'").trim()
                    def docaSha = sh(returnStdout: true, script:
                        "git -C ${env.DOCA_DIR} rev-parse --short HEAD 2>/dev/null || echo '<unknown>'").trim()
                    echo "DOCA alignment anchor: branch=${params.DOCA_BRANCH} " +
                         "version=${docaVer} sha=${docaSha}"
                    sh "mkdir -p ${env.WORKDIR}"
                    writeFile file: "${env.WORKDIR}/doca_alignment.json",
                              text: groovy.json.JsonOutput.toJson([
                                  doca_branch  : params.DOCA_BRANCH,
                                  doca_version : docaVer,
                                  doca_sha     : docaSha,
                              ])
                    archiveArtifacts artifacts: '_run/doca_alignment.json',
                                     allowEmptyArchive: false
                }
            }
        }

        stage('Install runner deps') {
            steps {
                sh """
                    python${DEFAULTS.PYTHON_VERSION} -m venv ${env.WORKDIR}/venv
                    ${env.WORKDIR}/venv/bin/pip install --upgrade pip
                    ${env.WORKDIR}/venv/bin/pip install pyyaml ${DEFAULTS.SKILLS_REF_VERSION} claude-skill-check
                """
            }
        }

        stage('Strict inventory alignment — skills 1:1 with doca/ (HARD)') {
            steps {
                script {
                    def rc = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-doca-inventory.sh
                    """)
                    if (rc != 0) {
                        error("Strict-to-doca inventory gate failed. " +
                              "Bundle not 1:1 with doca/{libs,services,tools} at DOCA_BRANCH=${params.DOCA_BRANCH}.")
                    }
                }
            }
        }

        stage('Per-skill conformance (HARD)') {
            steps {
                script {
                    sh """
                        SKILLS_ROOT=${env.SKILLS_DIR}/skills \\
                          bash ${env.SKILLS_DIR}/ci/check-skill.sh --all --check-urls
                        SKILLS_ROOT=${env.SKILLS_DIR}/skills \\
                          bash ${env.SKILLS_DIR}/ci/check-skill.sh --self-test
                    """
                }
            }
        }

        stage('Class-shape gate — runner/prompts/ (HARD)') {
            steps {
                script {
                    def rc = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-skill.sh \\
                          --check-class-shape ${env.SKILLS_DIR}/runner/prompts
                    """)
                    if (rc != 0) {
                        error("Class-shape gate failed on runner/prompts/. " +
                              "Rename prompts to name a CLASS not an INSTANCE; see AUTHORING § 1a / § 13.")
                    }
                }
            }
        }

        stage('Frontmatter (claude-skill-check) — HARD') {
            steps {
                script {
                    def rc = sh(returnStatus: true, script: """
                        set +e
                        overall_rc=0
                        for skill in \$(find ${env.SKILLS_DIR}/skills -name SKILL.md); do
                            out="\$(${env.WORKDIR}/venv/bin/claude-skill-check \"\$skill\" 2>&1)"
                            echo "\$out"
                            errs=\$(echo "\$out" | grep -oE '[0-9]+ error\\(s\\)' | head -1 | grep -oE '[0-9]+')
                            if [ -n "\$errs" ] && [ "\$errs" -gt 0 ]; then
                                overall_rc=1
                            fi
                        done
                        exit \$overall_rc
                    """)
                    if (rc != 0) {
                        error("claude-skill-check reported real errors. HARD GATE.")
                    }
                }
            }
        }

        stage('Cross-link integrity (HARD)') {
            steps {
                script {
                    def rc = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-crosslinks.sh
                    """)
                    if (rc != 0) {
                        error("Cross-link integrity gate failed. See log for source file + target.")
                    }
                }
            }
        }

        stage('Anchor density — no stub anchors (HARD)') {
            steps {
                script {
                    def rc = sh(returnStatus: true, script: """
                        SKILLS_ROOT=${env.SKILLS_DIR}/skills \\
                          bash ${env.SKILLS_DIR}/ci/check-anchor-density.sh --all
                    """)
                    if (rc != 0) {
                        error("Anchor-density gate failed. Some required H2 anchor is present but under-filled.")
                    }
                }
            }
        }

        stage('Coverage — routing + per-artifact gates (HARD @ 100%)') {
            steps {
                script {
                    sh "bash ${env.SKILLS_DIR}/ci/check-coverage.sh"
                    sh """
                        bash ${env.SKILLS_DIR}/ci/check-coverage.sh --json \\
                          > ${env.WORKDIR}/coverage_report.json || true
                    """
                    def prc = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-coverage.sh \\
                          --prompt-coverage-hard-fail >/dev/null
                    """)
                    if (prc != 0) {
                        error("Per-artifact PROMPT coverage gap. Every libs/services/tools skill MUST have ≥1 prompt naming it via baseline_artifact: (see AUTHORING § 15).")
                    }
                    def src = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-coverage.sh \\
                          --skill-coverage-hard-fail-below=100 >/dev/null
                    """)
                    if (src != 0) {
                        error("Per-artifact SKILL coverage below 100%. A public DOCA lib/service/tool is missing its 3-file skill dir.")
                    }
                }
            }
        }

        stage('Structural keystones (HARD — 42 keystones)') {
            steps {
                script {
                    // The keystone gate is the cheapest, fastest check
                    // we have against silent regressions of the
                    // load-bearing anchors (Stage 1/2 staged-roadmap,
                    // NGC tag selection rule, resume-point hand-off,
                    // per-library rollback overlays, universal
                    // verification + debug-loop contracts, etc.).
                    def rc = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-keystones.sh ${env.SKILLS_DIR}
                    """)
                    if (rc != 0) {
                        error("Structural keystone gate failed. At least one load-bearing structural anchor was removed or renamed. See the per-keystone log above.")
                    }
                }
            }
        }

        stage('Reference hygiene (HARD — reviewer-feedback regression guard)') {
            steps {
                script {
                    // No `../devops/` leaks, no missing local files,
                    // no misleading anchor labels, no audit-history
                    // inside runtime SKILL.md, no .DS_Store. This is
                    // the gate that ensures the May-2026 reviewer's
                    // feedback can never regress.
                    def rc = sh(returnStatus: true, script: """
                        python3 ${env.SKILLS_DIR}/ci/check-reference-hygiene.py \\
                          --bundle-root ${env.SKILLS_DIR}
                    """)
                    if (rc != 0) {
                        error("Reference-hygiene gate failed. See log for the offending file + violation class.")
                    }
                }
            }
        }

        stage('Frontmatter-kind gate (HARD — catches library-skeleton inheritance bug)') {
            steps {
                script {
                    // Catches services / tools whose SKILL.md was spawned
                    // from a library skeleton and silently kept
                    // `kind: library` in YAML frontmatter. Surfaced by the
                    // operational AI re-grade: 24 of 24 services+tools had
                    // wrong kind values before this gate landed. Without
                    // the gate, every consumer of frontmatter (loader UI,
                    // generated SKILLS.md table, agent-side classification)
                    // misreports the artifact's category.
                    def rc = sh(returnStatus: true, script: """
                        python3 ${env.SKILLS_DIR}/ci/check-frontmatter-kind.py
                    """)
                    if (rc != 0) {
                        error("Frontmatter-kind gate failed. Fix the listed SKILL.md files so each declares the correct kind: value.")
                    }
                }
            }
        }

        stage('Live-hardware harness self-test (fixtures mode; HARD)') {
            steps {
                script {
                    // Verifies that runner/run_with_live_hardware.py
                    // behaves correctly without a connected BlueField:
                    // auto-fallback to fixtures, fixtures mode produces
                    // a valid manifest, live/dry-run modes fail clean,
                    // mutating-token rejection list intact, v1 builder
                    // import integrity. 6/6 sub-tests must pass.
                    def rc = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-live-hardware-harness.sh
                    """)
                    if (rc != 0) {
                        error("Live-hardware-harness self-test failed. See log for the failing sub-test.")
                    }
                }
            }
        }

        stage('Live-hardware capture (real BlueField; opt-in)') {
            when {
                expression { return params.ENABLE_LIVE_HW }
            }
            steps {
                script {
                    // Only runs when the operator explicitly opted in
                    // AND a real BlueField is visible. The harness
                    // itself refuses to run if lspci doesn't show one.
                    def rc = sh(returnStatus: true, script: """
                        ${env.WORKDIR}/venv/bin/python ${env.SKILLS_DIR}/runner/run_with_live_hardware.py \\
                          --mode live \\
                          --target-host \$(hostname) \\
                          --out-dir ${env.WORKDIR}/lane_c_v2_live \\
                          > ${env.WORKDIR}/live_hw_capture.log 2>&1
                    """)
                    archiveArtifacts artifacts: '_run/live_hw_capture.log,_run/lane_c_v2_live/**',
                                     allowEmptyArchive: true
                    if (rc != 0) {
                        unstable("Live-hardware capture exited non-zero. SOFT WARN — the fixture self-test above is the load-bearing gate; the live capture is for capture artifacts only.")
                    }
                }
            }
        }

        stage('JTBD coverage (SOFT WARN)') {
            steps {
                script {
                    def rc = sh(returnStatus: true, script: """
                        bash ${env.SKILLS_DIR}/ci/check-jtbd-coverage.sh \\
                          > ${env.WORKDIR}/jtbd_coverage.log 2>&1
                    """)
                    archiveArtifacts artifacts: '_run/jtbd_coverage.log',
                                     allowEmptyArchive: true
                    sh "cat ${env.WORKDIR}/jtbd_coverage.log"
                    if (rc != 0) {
                        unstable("JTBD coverage gate reported issues. SOFT WARN by default.")
                    }
                }
            }
        }

        stage('Lint — PREVIOUS_REV baseline (sanity check)') {
            steps {
                script {
                    sh """
                        cd ${env.SKILLS_DIR}
                        git worktree add ../skills_prev ${params.PREVIOUS_REV} || true
                        SKILLS_ROOT=${env.WORKSPACE}/skills_prev/skills \\
                          bash ${env.SKILLS_DIR}/ci/check-skill.sh --all --check-urls || true
                    """
                }
            }
        }

        stage('NGC container preflight') {
            when {
                expression { return params.DOCA_NGC_TAG?.trim() != '' }
            }
            steps {
                script {
                    withEnv(["DOCA_NGC_TAG=${params.DOCA_NGC_TAG}"]) {
                        sh "bash ${env.SKILLS_DIR}/env/ngc_container.sh pull"
                    }
                }
            }
        }

        stage('Select prompts (FULL_BUNDLE_SMOKE-aware)') {
            steps {
                script {
                    // FULL_BUNDLE_SMOKE defaults to TRUE per the
                    // reviewer-feedback wave: every PR produces full
                    // per-artifact verdicts. Flip to false to use the
                    // diff-driven subset from select_prompts.py.
                    def smoke = params.FULL_BUNDLE_SMOKE ? "--include-all-if-empty" : ""
                    sh """
                        ${env.WORKDIR}/venv/bin/python ${env.SKILLS_DIR}/runner/select_prompts.py \\
                          --prompts-dir ${env.SKILLS_DIR}/runner/prompts \\
                          --skills-repo ${env.SKILLS_DIR} \\
                          --since ${params.PREVIOUS_REV} \\
                          --print-decision \\
                          ${smoke} \\
                          > ${env.WORKDIR}/selected_prompts.txt \\
                          2> ${env.WORKDIR}/selected_prompts.decision.log
                    """
                    archiveArtifacts artifacts: '_run/selected_prompts.txt,_run/selected_prompts.decision.log',
                                     allowEmptyArchive: false
                    def count = sh(returnStdout: true, script:
                        "wc -l < ${env.WORKDIR}/selected_prompts.txt").trim()
                    echo "Prompt selection: ${count} prompts (FULL_BUNDLE_SMOKE=${params.FULL_BUNDLE_SMOKE})."
                }
            }
        }

        stage('A/B/C run (baseline / main / pr)') {
            when {
                expression {
                    return env.AGENT_ADAPTER?.trim() && env.JUDGE_ADAPTER?.trim()
                }
            }
            steps {
                script {
                    def dryRun = params.APP_EXAMPLE_DRY_RUN ? "--app-example-dry-run" : ""
                    withEnv(["DOCA_NGC_TAG=${params.DOCA_NGC_TAG}",
                             "PYTHONPATH=${env.SKILLS_DIR}/runner"]) {
                        sh """
                            PROMPTS_FILES=\$(tr '\\n' ' ' < ${env.WORKDIR}/selected_prompts.txt)
                            ${env.WORKDIR}/venv/bin/python ${env.SKILLS_DIR}/runner/ab_runner.py \\
                              --skills-repo ${env.SKILLS_DIR} \\
                              --prompts-files \$PROMPTS_FILES \\
                              --rubric ${env.SKILLS_DIR}/runner/rubric/scoring_schema.yaml \\
                              --out ${env.REPORT_DIR} \\
                              --workdir ${env.WORKDIR}/runner_state \\
                              --previous-rev ${params.PREVIOUS_REV} \\
                              --current-rev HEAD \\
                              --agent-adapter \"${env.AGENT_ADAPTER}\" \\
                              --judge-adapter \"${env.JUDGE_ADAPTER}\" \\
                              --ngc-helper ${env.SKILLS_DIR}/env/ngc_container.sh \\
                              --coverage-json ${env.WORKDIR}/coverage_report.json \\
                              ${dryRun}
                        """
                    }
                }
            }
        }

        stage('Publish report') {
            steps {
                script {
                    if (fileExists("${env.REPORT_DIR}/report.html")) {
                        archiveArtifacts artifacts: '_run/report/**', allowEmptyArchive: false
                        publishHTML([
                            reportName            : 'doca-skills A/B/C report',
                            reportDir             : '_run/report',
                            reportFiles           : 'report.html',
                            allowMissing          : false,
                            keepAll               : true,
                            alwaysLinkToLastBuild : true,
                        ])
                    } else {
                        echo "No report.html produced — skipping publish. " +
                             "(A/B/C stage may have been skipped because " +
                             "AGENT_ADAPTER / JUDGE_ADAPTER were not set.)"
                    }
                }
            }
        }

        stage('No-regression gate (HARD — vs runner/baseline_grades.json)') {
            // The "every commit improves or at least does not damage" gate.
            // Compares the C-variant grades the A/B/C run just produced
            // against the committed baseline at runner/baseline_grades.json
            // (frozen via ci/freeze-baseline.py on the last green run).
            //
            // Project rule (verbatim from the project owner): "no way we
            // have regression and we do not fix before push — we have in
            // each commit to improve or at least not making damage."
            //
            // Skipped automatically when (a) no A/B/C run produced a
            // grades/ directory this build, or (b) the baseline file does
            // not yet exist (bootstrap case — ci/freeze-baseline.py
            // produces it after the first known-green run).
            when {
                expression {
                    return fileExists("${env.SKILLS_DIR}/runner/baseline_grades.json") &&
                           fileExists("${env.REPORT_DIR}/grades")
                }
            }
            steps {
                script {
                    def rc = sh(returnStatus: true, script: """
                        python3 ${env.SKILLS_DIR}/ci/check-no-regression.py \\
                          --current  ${env.REPORT_DIR}/grades \\
                          --baseline ${env.SKILLS_DIR}/runner/baseline_grades.json \\
                          --variant  C
                    """)
                    if (rc != 0) {
                        error("No-regression gate failed: at least one cell went PASS -> FAIL since the baseline. See log above. " +
                              "Project rule: every commit improves or at least does not damage.")
                    }
                }
            }
        }

        stage('Post PR comment (GitHub)') {
            when {
                allOf {
                    expression { return env.CHANGE_ID?.trim() } // only for PR builds
                    expression { return fileExists("${env.REPORT_DIR}/report.json") }
                }
            }
            steps {
                script {
                    withCredentials([string(credentialsId: Constants.GITHUB_HTTPS_CRED_ID,
                                            variable: 'GITHUB_API_TOKEN_FOR_COMMENT')]) {
                        def report   = readJSON(file: "${env.REPORT_DIR}/report.json")
                        def agg      = report.per_variant_aggregate
                        def buildUrl = "${env.BUILD_URL}artifact/_run/report/report.html"
                        def body = """\
**doca-skills A/B/C summary** (baseline / main / pr)
- baseline (no skills):       ${agg.baseline ?: '?'}
- main     (PREVIOUS_REV):    ${agg.previous ?: '?'}
- pr       (current HEAD):    ${agg.current ?: '?'}

Full report: ${buildUrl}

(Gate verdicts are separate commit-status checks.)
""".stripIndent()
                        def repoSlug = (env.CHANGE_URL =~ /github\.com\/([^\/]+\/[^\/]+)\/pull/)[0][1]
                        def commentJson = groovy.json.JsonOutput.toJson([body: body])
                        writeFile file: "${env.WORKDIR}/pr_comment.json", text: commentJson
                        sh """
                            curl -sS -X POST \\
                              -H "Authorization: token \$GITHUB_API_TOKEN_FOR_COMMENT" \\
                              -H "Accept: application/vnd.github+json" \\
                              --data @${env.WORKDIR}/pr_comment.json \\
                              https://api.github.com/repos/${repoSlug}/issues/${env.CHANGE_ID}/comments \\
                              > ${env.WORKDIR}/pr_comment.response.json
                        """
                        archiveArtifacts artifacts: '_run/pr_comment.json,_run/pr_comment.response.json',
                                         allowEmptyArchive: true
                    }
                }
            }
        }

        stage('Apply gates') {
            steps {
                script {
                    def reportJson = "${env.REPORT_DIR}/report.json"
                    if (!fileExists(reportJson)) {
                        echo "No report.json — gates skipped (A/B/C did not produce a report)."
                        return
                    }
                    def report = readJSON(file: reportJson)
                    def triggered = report.gates.findAll { it.triggered }
                    if (triggered.isEmpty()) {
                        echo "All gates passed."
                        return
                    }
                    triggered.each { g ->
                        echo "GATE TRIGGERED [${g.severity}] ${g.id}: ${g.message}"
                    }
                    unstable("Gates triggered: " + triggered.collect { it.id }.join(', '))
                }
            }
        }
    }

    post {
        always {
            script {
                if (fileExists("${env.REPORT_DIR}/report.json")) {
                    def report = readJSON(file: "${env.REPORT_DIR}/report.json")
                    def agg = report.per_variant_aggregate
                    echo "=== doca-skills A/B/C summary === " +
                         "baseline=${agg.baseline ?: '?'} " +
                         "main=${agg.previous ?: '?'} " +
                         "pr=${agg.current ?: '?'} " +
                         "(higher is better)"
                }
            }
        }
        cleanup {
            echo "Build ${currentBuild.result ?: 'SUCCESS'}."
        }
    }
}

{
  "capabilities": [
    {
      "id": "doca-sdk",
      "path": "contracts/capabilities/doca-sdk.json",
      "source_globs": [
        "VERSION",
        "meson.build",
        "meson_options.txt",
        "libs/**/include/public/**/*.h",
        "samples/**/meson.build",
        "applications/**/meson.build"
      ]
    }
  ],
  "schema_version": "1.0",
  "tasks": [
    {
      "command_kind": "build",
      "id": "build-sdk-sample",
      "path": "contracts/tasks/build-sdk-sample.yaml",
      "risk_class": "local-write",
      "source_globs": [
        "meson.build",
        "meson_options.txt",
        "samples/**/meson.build",
        "samples/**/dependencies/meson.build",
        "applications/**/meson.build",
        "applications/**/dependencies/meson.build"
      ]
    },
    {
      "command_kind": "discovery",
      "id": "discover-doca-environment",
      "path": "contracts/tasks/discover-doca-environment.yaml",
      "risk_class": "read-only",
      "source_globs": [
        "VERSION",
        "meson.build",
        "meson_options.txt",
        "libs/**/include/public/**/*.h"
      ]
    }
  ],
  "validation": {
    "commands": [
      "find contracts -maxdepth 2 -type f -print",
      "find skills -maxdepth 2 -name SKILL.md -print"
    ],
    "tool_calls": [
      {
        "argv": [
          "find",
          "contracts",
          "-maxdepth",
          "2",
          "-type",
          "f",
          "-print"
        ],
        "command": "find contracts -maxdepth 2 -type f -print",
        "id": "contract-files",
        "purpose": "List packaged contract files."
      },
      {
        "argv": [
          "find",
          "skills",
          "-maxdepth",
          "2",
          "-name",
          "SKILL.md",
          "-print"
        ],
        "command": "find skills -maxdepth 2 -name SKILL.md -print",
        "id": "skill-files",
        "purpose": "List packaged Agent Skill files."
      }
    ]
  }
}
